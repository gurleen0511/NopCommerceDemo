{
  "name": "nopcommerce-playwright-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright automation portfolio for demo.nopcommerce.com manual test suite",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf playwright-report test-results cloudflare_profile .auth",
    "test": "playwright test",
    "test:list": "playwright test --list",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
